---
// assets
import { Image } from "astro:assets";
import photo from "../../assets/images/decker.jpg"; // change to your image
import Github from "../../assets/icons/Github.astro";
import Linkedin from "../../assets/icons/Linkedin.astro";
import Twitter from "../../assets/icons/Twitter.astro";

// components
import Text from "../elements/Text.astro";
import NavBar from "./NavBar.astro";

// header content -> modify here!
const {
    role = "Software Engineer",
    name = "Andy Decker",
    status = "Available for work"
} = Astro.props;

const socials = [
    { link: "https://github.com", icon: Github },
    { link: "https://linkedin.com", icon: Linkedin },
    { link: "https://x.com", icon: Twitter }
]
---

<header class="flex flex-col gap-24 px-32 pt-56 bg-base-950 sticky top-56">
    <div class="flex flew-row gap-16 items-center">
        <Image src={photo} alt="Andy Decker" width={200} height={200} densities={[1,1.5,2]} class="object-cover object-center w-25 h-25 sepia-50 drop-shadow-md" />
        <div class="flex flex-row justify-between items-center w-full">
            <div class="flex flex-col gap-24">
                <div class="flex flex-col">
                    <Text variant={'normal'} class="text-base-700">// {role}</Text>
                    <Text variant={'xl'}>{name}</Text>
                </div>
                <div class="flex flex-row gap-24">
                    {
                        socials.map((social) => {
                            const Icon = social.icon;
                            return (
                                <a href={social.link} class="text-base-100 hover:text-base-300">
                                    <Icon width={20} height={20} fill="currentColor" />
                                </a>
                                )
                        })
                    }
                </div>
            </div>
            <div class="bg-base-950 drop-shadow-md p-8">
                <Text variant={'sm'} class="text-base-200">{status}</Text>
            </div>
        </div>
    </div>
    <NavBar />
</header>