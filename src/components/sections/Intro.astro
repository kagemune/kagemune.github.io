---
// components
import Heading from "../elements/Heading.astro";
import Text from "../elements/Text.astro";
---

<section aria-label="Introduction" class="flex flex-col gap-24">
    <div class="flex flex-col gap-16">
        <Text variant={'normal'} class="text-base-700">// Introduction</Text>
        <Heading tagName="h1" tagSize="h1">Hey There!</Heading>
    </div>
    <Text variant={'normal'} class="text-base-400">Hi, I’m Andy Decker — a software engineer focused on building reliable, scalable systems that make complex things feel simple. I work full-stack across areas like payments, bridging, and distributed infrastructure, with a strong emphasis on testing, observability, and clear documentation to improve both speed and confidence in what I ship.</Text>
</section>